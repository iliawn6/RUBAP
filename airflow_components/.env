# Fernet key for encrypting connection passwords
AIRFLOW__CORE__FERNET_KEY=mGENHUxCNF_u_WLQ8gngUYVQB0mjpqpXZI6Sw2ocOVo=

# MinIO (Data Lake) connection for S3Hook
# conn_type=aws, endpoint_url=http://minio:9000
